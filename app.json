{
    "expo": {
        "name": "IMS-Artecha",
        "slug": "ims-artecha",
        "privacy": "public",
        "sdkVersion": "32.0.0",
        "platforms": [
            "ios",
            "android"
        ],
        "version": "1.0.0",
        "orientation": "portrait",
        "icon": "./assets/icon.png",
        "splash": {
            "image": "./assets/splash.png",
            "resizeMode": "contain",
            "backgroundColor": "#ffffff"
        },
        "updates": {
            "fallbackToCacheTimeout": 0
        },
        "assetBundlePatterns": [
            "**/*"
        ],
        "ios": {
            "supportsTablet": true,
            "infoPlist": {
                "UIBackgroundModes": [
                    "location",
                    "fetch"
                ]
            },
            "bundleIdentifier": "com.bennsmith.imsartecha"
        },
        "android": {
            "package": "com.bennsmith.imsartecha"
        },
        "description": "IMS application developed for ARTECHA\n\nversion: beta 2.0"
    }
}